{
  "name": "BLACK PANTHER MD",
  "description": "BLACK PANTHER - A Powerful Multi-Device WhatsApp Bot built by Koyoteh to Enhance Your WhatsApp Experience",
  "repository": "https://github.com/koyoteh/BLACK-PANTHER",
  "keywords": ["black-panther", "koyoteh", "whatsapp-bot", "black-panther-md"],
  "env": {
    "SESSION_ID": {
      "description": "Your WhatsApp SESSION_ID from the pairing page",
      "required": true
    },
    "MODE": {
      "description": "Bot mode: public or private",
      "value": "BLACK PANTHER",
      "required": false
    },
    "OWNER_NAME": {
      "description": "Owner display name",
      "value": "Koyoteh",
      "required": false
    },
    "TIME_ZONE": {
      "description": "Your timezone e.g. Africa/Nairobi",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "free"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
}
