# ── Development / Editor ──────────────────────────────────────
.git
.gitignore
.replit
replit.md
.local/
.agents/
*.md
*.log

# ── Node modules — MUST be excluded so Docker does a fresh install
# (Replit uses NixOS; its compiled binaries won't run on Heroku Debian)
node_modules/

# ── Session & database files (runtime data, not part of image)
sessions/
*.db
*.db-shm
*.db-wal
whatsasena.json

# ── Environment / secrets
.env
.env.*

# ── Dev / test artifacts
coverage/
.nyc_output/
*.test.js
__tests__/

# ── OS artifacts
.DS_Store
Thumbs.db
